# Chat provider: "azure" (default), "github" (GitHub Models, free, no Azure quota)
# or "groq" (Groq, free tier, fast, chat only — no embeddings)
LLM_PROVIDER=azure
# Embeddings provider: "azure" (default) or "github" (separate rate limit from Azure)
EMBEDDING_PROVIDER=azure

# Azure OpenAI — required only when LLM_PROVIDER=azure and/or EMBEDDING_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
# Required only when LLM_PROVIDER=azure (the chat deployment name)
AZURE_OPENAI_DEPLOYMENT_NAME=
# Required only when EMBEDDING_PROVIDER=azure (the embeddings deployment name)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# GitHub Models — used only when LLM_PROVIDER=github
# Create a GitHub token with the "models:read" permission.
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
GITHUB_MODELS_CHAT_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_EMBEDDING_MODEL=openai/text-embedding-3-small

# Groq — used only when LLM_PROVIDER=groq (chat only, no embeddings support)
# Create a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_ENDPOINT=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Database — a SINGLE Postgres (with the pgvector extension) backs BOTH the
# document vector store AND chat-session persistence. Start it with
# `docker compose up -d` (docker-compose.yaml at the repo root uses the
# pgvector/pgvector image). No separate vector database is needed.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=corporatebrain
POSTGRES_USER=corporatebrain
POSTGRES_PASSWORD=corporatebrain

# Retrieval relevance cutoff (cosine distance, 0..2; lower = stricter). Chunks
# above this distance are dropped from the answer context (FIX-009). pgvector's
# default space is cosine, so this differs from the old Chroma (L2) scale —
# tune empirically with in-scope / out-of-scope questions. Default: 0.6.
# MAX_RELEVANT_DISTANCE=0.6

# Branding (optional — customizes the app for your company)
BRAND_NAME=Knowledge Base
BRAND_COLOR=#6c63ff
# BRAND_LOGO_PATH=./assets/logo.png

# Developer-only: shows a detailed retrieval debug panel (chunks, distance
# scores, top-k, chunk size/overlap, model names) under each answer. Token
# usage always shows regardless of this flag. Leave unset/false in normal use.
# DEBUG_MODE=true
